{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Mannco.store API",
  "description": "Complete API documentation for Mannco.store - Buy and sell TF2, CS:GO, Dota 2, Rust and Steam community items on the cheapest secured marketplace.",
  "colors": {
    "primary": "#29CCE0",
    "light": "#29CCE0",
    "dark": "#29CCE0"
  },
  "appearance": {
    "default": "dark",
    "strict": true
  },
  "background": {
    "color": {
      "light": "#021214",
      "dark": "#021214"
    },
    "decoration": "gradient"
  },
  "favicon": "/favicon.svg",
  "api": {
    "openapi": "openapi.json",
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "languages": ["curl", "python", "javascript"]
    }
  },
  "contextual": {
    "options": ["copy", "view", "download-spec"]
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Getting Started",
        "icon": "rocket",
        "openapi": "openapi.json",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "index",
              "api-reference/introduction"
            ]
          },
          {
            "group": "Authentication",
            "pages": [
              "api-reference/authentication",
              "POST /user/login"
            ]
          }
        ]
      },
      {
        "tab": "Buyer",
        "icon": "cart-shopping",
        "openapi": "openapi.json",
        "groups": [
          {
            "group": "Purchasing",
            "pages": [
              {
                "group": "Items",
                "pages": [
                  "GET /item/details/{item}",
                  "GET /item/salesGraph/{item}",
                  "GET /item/listing/count/{item}",
                  "GET /item/listing/{item}",
                  "GET /item/buyorderList/{item}",
                  "GET /item/prices",
                  "GET /item/pricing/{item}",
                  "GET /item/pricing/bulk",
                  "GET /item/details/fromid/{backpackid}",
                  "GET /item/cs/details/fromid/{backpackid}"
                ]
              },
              {
                "group": "Offers",
                "pages": [
                  "api-reference/offers/status-codes",
                  "GET /offers/received",
                  "GET /offers/my",
                  "POST /offers/create",
                  "POST /offers/accept",
                  "POST /offers/decline",
                  "POST /offers/remove"
                ]
              },
              {
                "group": "Buy Orders",
                "pages": [
                  "POST /item/buyorder",
                  "POST /item/buyorder/update",
                  "POST /item/buyorder/remove",
                  "GET /user/buyorder/{item}",
                  "GET /user/getBuyorder"
                ]
              },
              "POST /payment/{provider}"
            ]
          },
          {
            "group": "Cart",
            "pages": [
              "GET /cart/get",
              "POST /cart/add",
              "POST /cart/bulk",
              "POST /cart/remove",
              "POST /cart/update"
            ]
          }
        ]
      },
      {
        "tab": "Seller",
        "icon": "tag",
        "openapi": "openapi.json",
        "groups": [
          {
            "group": "Listing",
            "pages": [
              "GET /deposit/{game}",
              "POST /deposit/trade",
              "GET /deposit/instantSell/{game}",
              "POST /deposit/trade/instant",
              "GET /deposit/tradeStatus/{tradeid}"
            ]
          },
          {
            "group": "Inventory",
            "pages": [
              "GET /inventory/onSale",
              "GET /inventory/onInventory",
              "POST /inventory/price",
              "POST /inventory/withdraw",
              "api-reference/inventory/item-states"
            ]
          }
        ]
      },
      {
        "tab": "Trading",
        "icon": "arrows-rotate",
        "openapi": "openapi.json",
        "groups": [
          {
            "group": "Trades",
            "pages": [
              "GET /trades/active",
              "GET /trades/all",
              "GET /trade/resend"
            ]
          }
        ]
      },
      {
        "tab": "User Account",
        "icon": "user",
        "openapi": "openapi.json",
        "groups": [
          {
            "group": "Account",
            "pages": [
              "GET /user/infos",
              "GET /user/balance",
              "GET /user/notifications",
              "GET /user/ipList",
              "GET /user/store/{identifier}",
              "GET /user/disconnect"
            ]
          },
          {
            "group": "Sales & Stats",
            "pages": [
              "GET /user/getSalesInfos",
              "GET /user/getSalesChartInfos"
            ]
          },
          {
            "group": "History",
            "pages": [
              "GET /user/getBalanceHistory",
              "GET /user/getPurchaseHistory",
              "GET /user/getSalesHistory",
              "GET /user/getCashoutHistory",
              "GET /user/getTransactionHistory",
              "GET /user/getTransactionDetails"
            ]
          }
        ]
      },
      {
        "tab": "WebSocket",
        "icon": "tower-broadcast",
        "groups": [
          {
            "group": "Realtime",
            "pages": [
              "api-reference/websocket/market-stream"
            ]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "https://mannco.store"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Mannco.store",
      "href": "https://mannco.store"
    }
  },
  "footer": {
    "socials": {
      "discord": "https://discord.gg/mannco"
    }
  }
}
